# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_бота

# Telegram Admin ID (ваш ID — узнать у @userinfobot)
TELEGRAM_ADMIN_ID=ваш_айди

# Telegram Channel ID (например @channel или -1001234567890)
TELEGRAM_CHANNEL_ID=@имя_канала

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=ваш_ключ

# Модель OpenRouter для генерации постов (бесплатно)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash-free

# Pexels API Key (https://www.pexels.com/api/) — опционально
PEXELS_API_KEY=

# Режим запуска: webhook или polling
BOT_MODE=webhook

# URL для webhook (ваш Render URL, например https://ваш-бот.onrender.com)
WEBHOOK_URL=

# Порт (Render сам назначает через PORT)
PORT=10000
